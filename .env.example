# =====================================================
# AI HONEYPOT SECURITY PLATFORM - ENVIRONMENT CONFIG
# =====================================================

# =====================================================
# APPLICATION SETTINGS
# =====================================================
DEBUG=True
ENVIRONMENT=development
APP_NAME=AI Honeypot Security Platform
APP_VERSION=1.0.0
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# =====================================================
# SECURITY & JWT
# =====================================================
SECRET_KEY=your-super-secret-key-change-this-in-production-12345
ALGORITHM=HS256
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =====================================================
# DATABASE
# =====================================================
DATABASE_URL=postgresql://postgres:password@postgres:5432/honeypot_db
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=honeypot_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# =====================================================
# REDIS CACHE
# =====================================================
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_TTL=3600

# =====================================================
# HONEYPOT CONFIGURATION
# =====================================================
COWRIE_SSH_PORT=2222
COWRIE_TELNET_PORT=2323
COWRIE_HOSTNAME=honeypot-server
COWRIE_LOG_PATH=/data/cowrie/log

DIONAEA_PORT=8081
DIONAEA_LOG_PATH=/data/dionaea/log

# =====================================================
# MACHINE LEARNING
# =====================================================
ML_MODEL_TYPE=ensemble
ML_CONFIDENCE_THRESHOLD=0.75
ML_ANOMALY_THRESHOLD=0.85
MODEL_UPDATE_INTERVAL=3600
MODEL_PATH=./backend/models/trained
MODEL_RETRAIN_INTERVAL=86400

# ML Features
ML_USE_RANDOM_FOREST=True
ML_USE_XGBOOST=True
ML_USE_ISOLATION_FOREST=True
ML_ENSEMBLE_VOTING=hard

# =====================================================
# CORS & API
# =====================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["*"]

# =====================================================
# WEBSOCKET
# =====================================================
WS_URL=ws://localhost:8000/ws
WS_UPDATE_INTERVAL=5
WS_MAX_CONNECTIONS=1000

# =====================================================
# LOGGING
# =====================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# =====================================================
# EMAIL & NOTIFICATIONS
# =====================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@honeypot.local
SMTP_ENABLED=false

# =====================================================
# HONEYPOT COLLECTION
# =====================================================
HONEYPOT_LOG_AGGREGATION_INTERVAL=60
HONEYPOT_LOG_RETENTION_DAYS=30
HONEYPOT_ALERT_ON_SUCCESS=true
HONEYPOT_CAPTURE_COMMANDS=true
HONEYPOT_CAPTURE_FILES=true

# =====================================================
# ALERT SETTINGS
# =====================================================
ALERT_CRITICAL_THRESHOLD=90
ALERT_HIGH_THRESHOLD=70
ALERT_MEDIUM_THRESHOLD=50
ALERT_RETENTION_DAYS=90
ALERT_AUTO_ACKNOWLEDGE=false

# =====================================================
# REPORT GENERATION
# =====================================================
REPORT_FORMAT=pdf
REPORT_INCLUDE_CHARTS=true
REPORT_INCLUDE_TIMELINE=true
REPORT_INCLUDE_INTELLIGENCE=true

# =====================================================
# GEO-IP DATA
# =====================================================
GEOIP_DATABASE_PATH=./data/geoip/GeoLite2-City.mmdb
GEOIP_UPDATE_INTERVAL=604800

# =====================================================
# DOCKER CONFIGURATION
# =====================================================
DOCKER_NETWORK=honeypot-network
DOCKER_REGISTRY=
DOCKER_IMAGE_PREFIX=

# =====================================================
# BACKUP & MAINTENANCE
# =====================================================
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups

# =====================================================
# FEATURE FLAGS
# =====================================================
FEATURE_MALWARE_LAB=true
FEATURE_THREAT_INTELLIGENCE=true
FEATURE_AI_ANALYTICS=true
FEATURE_REAL_TIME_DASHBOARD=true
FEATURE_GEOGRAPHIC_MAP=true
FEATURE_SHAP_EXPLAINABILITY=true
FEATURE_CUSTOM_RULES=true
FEATURE_EXPORT_REPORTS=true
